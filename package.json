{
  "name": "templatus-inertia",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "format": "prettier . --write --plugin=@prettier/plugin-ruby --plugin=prettier-plugin-tailwindcss",
    "test": "vitest",
    "lint": "eslint --cache .",
    "tsc": "tsc --noEmit",
    "size": "bun run size-limit"
  },
  "dependencies": {
    "@honeybadger-io/js": "^6.14.0",
    "@inertiajs/svelte": "^3.6.1",
    "@plausible-analytics/tracker": "^0.4.5",
    "@rails/actioncable": "^8.1.300",
    "@tabler/icons-svelte": "^3.44.0",
    "timeago.js": "^4.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@prettier/plugin-ruby": "^4.0.4",
    "@size-limit/file": "^12.1.0",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/svelte": "^5.0.8",
    "@types/rails__actioncable": "^8.0.3",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitest/coverage-v8": "^4.1.10",
    "acorn": "^8.17.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-svelte": "^3.20.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "size-limit": "^12.1.0",
    "svelte": "^5.56.5",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vite-plugin-full-reload": "^1.2.0",
    "vite-plugin-rails": "^0.6.0",
    "vitest": "^4.1.10"
  },
  "trustedDependencies": [
    "@tailwindcss/oxide",
    "vite"
  ],
  "size-limit": [
    {
      "limit": "90 kB",
      "path": "public/{vite,vite-dev,vite-test}/assets/*.js"
    }
  ],
  "engines": {
    "bun": "1.3.x"
  }
}
