{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":disableDependencyDashboard"],
  "enabledManagers": ["bun"],
  "packageRules": [
    {
      "matchPackageNames": ["*"],
      "enabled": false
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"],
    "automerge": true,
    "automergeType": "pr",
    "commitMessageAction": "refresh",
    "commitMessageTopic": "bun.lock"
  }
}
